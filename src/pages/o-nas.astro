---
import Layout from '../layouts/Layout.astro';
import { getAuthor, assetUrl } from '../lib/contentful';

const author: any = await getAuthor();

const name = author?.fields?.name || 'Julka i Radek';
const bio = author?.fields?.bio || 'Od pięciu lat zapisujemy każdą podróż — bilety, ślady GPX, ceny chleba na bazarach. Tu spisujemy to wszystko zamiast gubić w notatkach telefonu. Najczęściej Bałkany, Kaukaz i północ. Najchętniej autobusem, marszrutką, stopem.';
const avatar = author?.fields?.avatar ? assetUrl(author.fields.avatar, { w: 1200 }) : 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=1200&q=80';
const instagram = author?.fields?.instagram || 'gajowka.w.drodze';
const signature = author?.fields?.signature || '— do zobaczenia w drodze';
---
<Layout title="o nas">
  <section class="container-edge pt-32 pb-20 grid md:grid-cols-2 gap-16 items-center">
    <div class="aspect-[4/5] bg-cover bg-center sepia-[0.15] saturate-[0.9]" style={`background-image: url('${avatar}');`} data-reveal></div>
    <div data-reveal>
      <div class="eyebrow mb-3">o nas</div>
      <h1 class="font-serif italic text-6xl mb-8 leading-tight">cześć, jesteśmy <span class="text-rust">{name}</span></h1>
      <div class="text-ink-soft text-lg space-y-5 whitespace-pre-wrap">{bio}</div>
      <p class="font-serif italic text-rust text-2xl mt-10">{signature}</p>
      <div class="mt-8">
        <a href={`https://instagram.com/${instagram}`} target="_blank" rel="noopener" class="btn-primary">
          @{instagram} ↗
        </a>
      </div>
    </div>
  </section>
</Layout>
