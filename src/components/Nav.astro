---
const links = [
  { href: '/#latest', label: 'podróże' },
  { href: '/mapa', label: 'mapa' },
  { href: '/#countries', label: 'kraje' },
  { href: '/o-nas', label: 'o nas' },
];
---
<nav class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center py-5 px-6 md:px-12 bg-bg/85 backdrop-blur-md border-b border-ink/10">
  <a href="/" class="font-serif italic text-xl text-ink flex items-center gap-3 hover:text-rust transition-colors">
    <img src="/gajowka.jpg" alt="" class="w-9 h-9 rounded-full object-cover" />
    gajówka w drodze
  </a>
  <ul class="hidden md:flex gap-10 list-none">
    {links.map(l => (
      <li>
        <a href={l.href} class="nav-link text-sm tracking-wide text-ink-soft hover:text-rust transition-colors relative">
          {l.label}
        </a>
      </li>
    ))}
    <li>
      <a href="https://instagram.com/gajowka.w.drodze" target="_blank" rel="noopener" class="text-sm tracking-wide text-rust hover:text-rust-dark transition-colors">
        instagram ↗
      </a>
    </li>
  </ul>
  <button id="nav-toggle" class="md:hidden text-ink-soft" aria-label="menu">☰</button>
</nav>

<div id="mobile-menu" class="hidden fixed inset-0 z-40 bg-bg pt-24 px-6">
  <ul class="flex flex-col gap-6 text-2xl font-serif">
    {links.map(l => <li><a href={l.href} class="text-ink-soft hover:text-rust">{l.label}</a></li>)}
    <li><a href="https://instagram.com/gajowka.w.drodze" target="_blank" rel="noopener" class="text-rust">instagram ↗</a></li>
  </ul>
</div>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: theme('colors.rust');
    transition: width 0.3s;
  }
  .nav-link:hover::after { width: 100%; }
</style>

<script>
  const btn = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.add('hidden')));
</script>
